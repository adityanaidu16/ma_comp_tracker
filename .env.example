# sec-api.io API key (get at https://sec-api.io/profile)
SEC_API_KEY=

# OpenRouter API key (get at https://openrouter.ai/keys)
OPENROUTER_API_KEY=

# SEC requires identifying contact info in the User-Agent. Replace with
# your own email — SEC will throttle if multiple users share one UA.
# Format follows SEC guidance: "company-or-project/version (contact: you@firm.com)"
SEC_USER_AGENT=ma_comp_tracker/0.1 (contact: your.name@yourfirm.com)

# Optional: override the OpenRouter model
# Default is deepseek/deepseek-chat (V4-Flash class) which is the cheapest
# capable model for SEC footnote extraction. Override with a more capable
# model (e.g. anthropic/claude-sonnet-4.5) if you want higher extraction
# accuracy at higher per-call cost.
OPENROUTER_MODEL=deepseek/deepseek-chat

# Drop acquisitions older than this many days from the CSV. Default 180
# (~ last two quarters). Increase to widen the window (e.g. 365 for the
# last year). Set to 0 to disable date filtering entirely.
MAX_ACQUISITION_AGE_DAYS=180

# Number of concurrent ticker workers. Higher = faster but more load on
# sec-api and OpenRouter. Default 8 — good balance for the standard comp
# set. Drop to 4 if you're hitting rate limits, raise to 16 for big sets.
MAX_WORKERS=8
